$ErrorActionPreference = 'silentlycontinue'

#Escape characters
function Set-EscapeCharacters {
    Param(
        [parameter(Mandatory = $true, Position = 0)]
        [String]
        $string
    )
    $string = $string -replace "'", "\'"
    $string = $string -replace "&", "and"
    $string = $string -replace "#", ""
    $string
}

#Centralsquare ODBC meter data
function Get-ODBC-Meter{
   param(
   [string]$query="SELECT * FROM UTSYNCAP WHERE UTMTR=$CSMeterNBR",
   [string]$dsn = "hostname.domain.com"
   )
   $conn = New-Object System.Data.Odbc.OdbcConnection
   $conn.ConnectionString = "DSN=$dsn;UID=;PWD="
   $conn.open()
   #$conn
   $cmd = New-object System.Data.Odbc.OdbcCommand($query,$conn)
   $ds = New-Object system.Data.DataSet
   (New-Object system.Data.odbc.odbcDataAdapter($cmd)).fill($ds) | out-null
   $conn.close()
  
   $ds.Tables[0]
   #$conn
}


