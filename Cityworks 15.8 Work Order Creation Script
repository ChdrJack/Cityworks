###Date

# Get the current system time
$Time = Get-Date
# Convert the time to Central Standard Time (CST)
$CSTTime = $Time.ToUniversalTime().AddHours(-5)

# Subtract 72 hours.
$m2Time = $CSTTime.AddHours(-72)

# Create time string for Cityworks
$CWDate = Get-Date $m2Time -Format 'yyyy-MM-ddTHH:mm:ssZ'
$CWDate

# Create time string for Central Square
$CSDate = Get-Date $m2Time -Format 'yyyyMMdd'
$CSDate

